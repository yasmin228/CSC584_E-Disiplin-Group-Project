<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Appointment List | E-Disiplin</title>
  <link rel="stylesheet" href="css/styles.css">
  <style>
    body {
      font-family: Tinos, sans-serif;
      background: url("img/background.jpg");
      background-size: cover;
      background-repeat: no-repeat;
      margin: 0;
      padding: 0;
    }
    .container {
      background: #fff;
      padding: 30px;
      border-radius: 8px;
      width: 90%;
      max-width: 1000px;
      margin: 40px auto;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    h1 {
      text-align: center;
      margin-bottom: 20px;
    }
    form {
      margin-bottom: 30px;
    }
    input, select {
      width: 95%;
      margin: 8px 0;
      padding: 10px;
      border: 1px solid #ccc;
      border-radius: 5px;
    }
    .button {
      font-family: Tinos, sans-serif;
      background: #527FFA;
      color: white;
      padding: 10px 20px;
      text-decoration: none;
      border-radius: 5px;
      cursor: pointer;
      border: none;
    }
    .button:hover {
      background: #2C4485;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }
    table, th, td {
      border: 1px solid #ccc;
    }
    th, td {
      padding: 10px;
      text-align: center;
    }
    .action-btn {
      margin: 0 5px;
      padding: 5px 10px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
    }
    .edit-btn {
      background: #4CAF50;
      color: white;
    }
    .delete-btn {
      background: #f44336;
      color: white;
    }
    .nav-link { 
        display: block; 
        margin-top: 20px; 
        text-align: center;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Counseling Appointments</h1>
    <table id="appointmentTable">
      <thead>
        <tr>
          <th>Incident ID</th>
          <th>Student</th>
          <th>Counselor</th>
          <th>Date/Time</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <!-- Rows will be loaded from localStorage -->
      </tbody>
    </table>
    <a href="add-appointment.html" class="nav-link">Add New Appointment</a>
  </div>
</body>
</html>
